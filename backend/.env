DATABASE_URL="file:./dev.db"

JWT_SECRET=super-secret-key-change-in-production
REFRESH_SECRET=super-refresh-secret-change-in-production
PORT=3000
NODE_ENV=development

FRONTEND_URL=http://localhost:4200

# Stripe (payments) - Development
# Use Stripe test mode keys from https://dashboard.stripe.com/test/apikeys
# Leave blank to run checkout in dev mode (direct grant, no real payment).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:4200/premium
STRIPE_CANCEL_URL=http://localhost:4200/premium