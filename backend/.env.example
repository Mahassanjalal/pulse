# App
DATABASE_URL="file:./dev.db"
JWT_SECRET=super-secret-key-change-in-production
REFRESH_SECRET=super-refresh-secret-change-in-production
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Google OAuth 2.0 - https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID for a Web application, add http://localhost:4200 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Uploaded images (profile/cover/chat media) live here on disk.
# In production point this at the Railway-mounted data volume, e.g. /data/uploads.
UPLOAD_DIR=/data/uploads
# Use Stripe TEST mode keys from https://dashboard.stripe.com/test/apikeys
# For local webhooks use the Stripe CLI: stripe listen --forward-to localhost:3000/api/v1/premium/webhook
# Leave STRIPE_SECRET_KEY blank to run checkout in dev mode (direct grant, no real payment).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:4200/premium
STRIPE_CANCEL_URL=http://localhost:4200/premium
